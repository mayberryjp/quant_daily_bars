POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quant
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant_dev_password
DATABASE_URL=postgresql+psycopg://quant:quant_dev_password@localhost:5432/quant

# Polygon.io API key for daily bar ingestion. Keep real credentials out of git.
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.polygon.io
MASSIVE_TIMEOUT_SECONDS=30
MASSIVE_RETRY_COUNT=3
MASSIVE_BACKOFF_SECONDS=0.5
MASSIVE_BACKOFF_MULTIPLIER=2
MASSIVE_PAGE_DELAY_SECONDS=12

# Ingestion schedule (seconds). Default: 86400 (24h).
INGEST_INTERVAL=86400
